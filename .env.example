# =============================================================================
# Copie este arquivo para ".env" e ajuste os valores conforme necessário.
# O ".env" real (com credenciais) NÃO deve ser versionado no Git.
# =============================================================================

# --- Fonte PostgreSQL (origem) — banco fornecido pelo curso, hospedado remotamente ---
SRC_PG_HOST=srv1236151.hstgr.cloud
SRC_PG_PORT=5433
SRC_PG_DB=dados_publicos
SRC_PG_USER=postgres
SRC_PG_PASSWORD=troque_pela_senha_fornecida

# --- Data Warehouse PostgreSQL (camada Gold, container local) ---
DW_PG_HOST=postgres-dw
DW_PG_PORT=5432
DW_PG_DB=dw_ceara
DW_PG_USER=dw_user
DW_PG_PASSWORD=dw_pass

# --- API REST Ceará Transparente (pública, sem autenticação) ---
API_BASE_URL=https://api-dados-abertos.cearatransparente.ce.gov.br
API_CONTRATOS_ENDPOINT=/transparencia/contratos/contratos

# --- HDFS (WebHDFS) ---
HDFS_WEBHDFS_URL=http://namenode:9870
HDFS_USER=root
HDFS_BRONZE_PATH=/data/bronze
HDFS_SILVER_PATH=/data/silver

# --- Janela de extração incremental (mantém o volume gerenciável em ambiente acadêmico) ---
# A extração incremental real usa a Airflow Variable "last_extracted_date" a partir da
# segunda execução; estas datas definem apenas o backfill inicial (primeira carga).
EXTRACT_START_DATE=2026-01-01
EXTRACT_END_DATE=2026-06-30

# --- IA Generativa (API OpenAI) ---
# Sem chave, o pipeline não falha: cai automaticamente para um relatório por template.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
